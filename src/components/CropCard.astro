---
import ConfidenceBadge from './ConfidenceBadge.astro';

interface Props {
  title: string;
  titleEn: string;
  scientificName?: string;
  summary: string;
  difficulty: 'easy' | 'moderate' | 'hard' | 'expert';
  timeToHarvest: string;
  href: string;
  confidence: 'high' | 'medium' | 'low' | 'uncertain';
  category: string;
  heroImage?: string;
}

const {
  title,
  titleEn,
  scientificName,
  summary,
  difficulty,
  timeToHarvest,
  href,
  confidence,
  category,
  heroImage,
} = Astro.props;

const difficultyMap = {
  easy: 'ง่าย',
  moderate: 'ปานกลาง',
  hard: 'ยาก',
  expert: 'ผู้เชี่ยวชาญ',
};
---

<a href={href} class="index-card block no-underline group hover:no-underline">
  {heroImage && (
    <div class="aspect-video rounded-card overflow-hidden mb-4 bg-rice-cream-dark -mx-6 -mt-6 mb-4">
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}

  <div class="flex items-start justify-between gap-3 mb-2">
    <div class="flex-1 min-w-0">
      <h3 class="text-h4 text-kaset-green-dark group-hover:text-kaset-green transition-colors mb-1 leading-tight">
        {title}
      </h3>
      <p class="text-sm text-charcoal-light">
        {titleEn}
        {scientificName && (
          <span class="italic"> · {scientificName}</span>
        )}
      </p>
    </div>
  </div>

  <p class="text-sm text-charcoal mb-4 line-clamp-3">
    {summary}
  </p>

  <div class="flex flex-wrap items-center gap-2 text-xs">
    <span class="badge-factor !text-xs !py-1">
      📊 {difficultyMap[difficulty]}
    </span>
    <span class="badge-factor !text-xs !py-1">
      ⏱️ {timeToHarvest}
    </span>
    <ConfidenceBadge level={confidence} />
  </div>
</a>
