---
// JsonLd — emits one or more <script type="application/ld+json"> blocks.
// Pass a single object or an array of structured-data objects.
//
// Usage:
//   import JsonLd from '@components/JsonLd.astro';
//   <JsonLd data={{ "@context": "https://schema.org", "@type": "Article", ... }} />
//   <JsonLd data={[organizationSchema, websiteSchema]} />
//
// Mounted into BaseLayout's <head> for site-wide structured data; consumers must supply schema.org-compliant @type values.

interface Props {
  data: Record<string, any> | Record<string, any>[];
}

const { data } = Astro.props;
const dataArray = Array.isArray(data) ? data : [data];
---

{dataArray.map((d) => (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(d)}
    is:inline
  />
))}
