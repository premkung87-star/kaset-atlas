---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConfidenceBadge from '../../components/ConfidenceBadge.astro';
import FactorBadge from '../../components/FactorBadge.astro';

export async function getStaticPaths() {
  const crops = await getCollection('crops', ({ data }) => !data.draft);
  return crops.map((crop) => ({
    params: { slug: crop.slug },
    props: { crop },
  }));
}

const { crop } = Astro.props;
const { Content } = await crop.render();

const category = await getEntry('categories', crop.data.category);

const difficultyMap = {
  easy: 'ง่าย',
  moderate: 'ปานกลาง',
  hard: 'ยาก',
  expert: 'ผู้เชี่ยวชาญ',
};

const waterMap = { low: 'น้อย', medium: 'ปานกลาง', high: 'มาก' };
const sunMap = { shade: 'ร่ม', partial: 'รำไร', full: 'แดดเต็มวัน' };

// Bilingual structured data (AI-citable goal — see docs/WORKFLOW_KIT.md §6)
const cropUrl = new URL(`/crops/${crop.slug}`, Astro.site).toString();
const allNames = [
  crop.data.titleEn,
  crop.data.scientificName,
  ...crop.data.aliases,
].filter(Boolean);

const keywordList = [
  crop.data.title,
  crop.data.titleEn,
  crop.data.scientificName,
  ...crop.data.aliases,
  category?.data.title,
  category?.data.titleEn,
  crop.data.family,
  'Thai agriculture',
  'การเกษตร',
  'ปลูกพืช',
  'Kaset Atlas',
].filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: crop.data.title,
  alternativeHeadline: allNames,
  name: crop.data.title,
  alternateName: allNames,
  description: crop.data.summary,
  inLanguage: 'th',
  url: cropUrl,
  datePublished: crop.data.publishedAt.toISOString(),
  dateModified: crop.data.lastUpdated.toISOString(),
  author: {
    '@type': 'Organization',
    name: crop.data.contributor,
    url: 'https://kasetatlas.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Kaset Atlas',
    alternateName: 'เกษตรแอตลาส',
    url: 'https://kasetatlas.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://kasetatlas.com/favicon.svg',
    },
  },
  license: 'https://creativecommons.org/licenses/by-sa/4.0/',
  isAccessibleForFree: true,
  keywords: keywordList.join(', '),
  about: {
    '@type': 'Thing',
    name: crop.data.scientificName || crop.data.titleEn,
    alternateName: [crop.data.title, ...allNames].filter(Boolean),
  },
  articleSection: category?.data.title || crop.data.category,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': cropUrl,
  },
};
---

<BaseLayout
  title={crop.data.title}
  description={crop.data.summary}
  jsonLd={jsonLd}
>
  <article class="container-page py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-charcoal-light mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-kaset-green-dark">หน้าแรก</a>
      <span class="mx-2">/</span>
      {category && (
        <>
          <a href={`/categories/${category.data.slug}`} class="hover:text-kaset-green-dark">
            {category.data.title}
          </a>
          <span class="mx-2">/</span>
        </>
      )}
      <span class="text-charcoal">{crop.data.title}</span>
    </nav>

    <!-- Header -->
    <header class="max-w-reading mx-auto mb-8">
      <div class="flex items-start gap-4 mb-4">
        <div class="flex-1">
          <h1 class="text-h1 text-kaset-green-dark mb-2">
            {crop.data.title}
            <span class="text-h3 text-charcoal-light font-normal block mt-1">
              {crop.data.titleEn}
            </span>
          </h1>
          {crop.data.scientificName && (
            <p class="text-sm italic text-charcoal-light">
              {crop.data.scientificName}
              {crop.data.family && <span> · วงศ์ {crop.data.family}</span>}
            </p>
          )}
        </div>
        <ConfidenceBadge level={crop.data.confidenceOverall} />
      </div>

      <p class="text-lead text-charcoal mb-6">{crop.data.summary}</p>

      <!-- Quick factors -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-6">
        <FactorBadge label="ความยาก" value={difficultyMap[crop.data.difficulty]} />
        <FactorBadge label="ระยะเวลา" value={crop.data.timeToHarvest} />
        <FactorBadge label="น้ำ" value={waterMap[crop.data.waterNeed]} />
        <FactorBadge label="แดด" value={sunMap[crop.data.sunNeed]} />
        {crop.data.soilTypes.length > 0 && (
          <FactorBadge label="ดิน" value={crop.data.soilTypes.join(', ')} />
        )}
      </div>
    </header>

    <!-- Main content -->
    <div class="max-w-reading mx-auto prose">
      <Content />
    </div>

    <!-- Best for / Not suitable -->
    {(crop.data.bestFor.length > 0 || crop.data.notSuitableFor.length > 0) && (
      <div class="max-w-reading mx-auto grid grid-cols-1 md:grid-cols-2 gap-4 my-12">
        {crop.data.bestFor.length > 0 && (
          <div class="bg-kaset-green/10 border border-kaset-green/20 rounded-card p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-kaset-green-dark mb-3">
              ✓ เหมาะสำหรับ
            </h3>
            <ul class="space-y-1.5 text-sm">
              {crop.data.bestFor.map((item) => (
                <li class="text-charcoal">• {item}</li>
              ))}
            </ul>
          </div>
        )}
        {crop.data.notSuitableFor.length > 0 && (
          <div class="bg-soil-brown/10 border border-soil-brown/20 rounded-card p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-soil-brown-dark mb-3">
              ✗ ไม่เหมาะสำหรับ
            </h3>
            <ul class="space-y-1.5 text-sm">
              {crop.data.notSuitableFor.map((item) => (
                <li class="text-charcoal">• {item}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}

    <!-- Last updated -->
    <footer class="max-w-reading mx-auto mt-16 pt-8 border-t border-charcoal/10">
      <div class="bg-rice-cream-dark/30 rounded-card p-5 text-sm text-charcoal-light">
        <p class="mb-1">
          <strong class="text-charcoal">ปรับปรุงล่าสุด:</strong>{' '}
          {crop.data.lastUpdated.toLocaleDateString('th-TH', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
        <p class="mb-1">
          <strong class="text-charcoal">ผู้เขียน:</strong> {crop.data.contributor}
        </p>
        {crop.data.reviewer && (
          <p class="mb-1">
            <strong class="text-charcoal">ผู้รีวิว:</strong> {crop.data.reviewer}
          </p>
        )}
        <p class="mt-3 text-xs">
          พบข้อผิดพลาดหรือมีแหล่งข้อมูลที่ดีกว่า?{' '}
          <a
            href={`https://github.com/premkung87-star/kaset-atlas/issues/new?title=แก้ไข: ${crop.data.title}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-water-blue"
          >
            แจ้งบน GitHub
          </a>
        </p>
      </div>
    </footer>
  </article>
</BaseLayout>
